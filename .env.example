# ── Server ───────────────────────────────────────────────────────────────
NODE_ENV=
PORT=

# ── Database ─────────────────────────────────────────────────────────────
DATABASE_URL=

# ── Auth / JWT ───────────────────────────────────────────────────────────
# Generate a secure secret:  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=

# ── OAuth ────────────────────────────────────────────────────────────────
OAUTH_SERVER_URL=
OWNER_OPEN_ID=

# ── NUMU API ─────────────────────────────────────────────────────────────
NUMU_API_URL=
NUMU_ADMIN_EMAIL=
NUMU_ADMIN_PASSWORD=

# ── Vite (client-side, must start with VITE_) ───────────────────────────
VITE_APP_ID=
VITE_OAUTH_PORTAL_URL=
VITE_FRONTEND_FORGE_API_KEY=
VITE_FRONTEND_FORGE_API_URL=

# ── Forge API (server-side) ──────────────────────────────────────────────
BUILT_IN_FORGE_API_URL=
BUILT_IN_FORGE_API_KEY=
